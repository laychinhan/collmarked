{
  "name": "collmarked",
  "version": "1.0.0",
  "description": "A CLI bookmark manager with hierarchical categories and tags",
  "main": "dist/index.js",
  "bin": {
    "collmarked": "./bin/run.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "cp -r src/db/migrations dist/db/migrations 2>/dev/null || true",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "oclif": {
    "bin": "collmarked",
    "dirname": "collmarked",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " "
  },
  "keywords": [
    "cli",
    "bookmark",
    "oclif"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@github/copilot-sdk": "^0.2.0",
    "@mozilla/readability": "^0.6.0",
    "@oclif/core": "^4.10.2",
    "@oclif/plugin-help": "^6.2.40",
    "better-sqlite3": "^12.8.0",
    "effect": "^3.21.0",
    "kysely": "^0.28.14",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
